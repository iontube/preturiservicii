---
import Layout from '../../layouts/Layout.astro';
import SEOHead from '../../components/SEOHead.astro';
import { servicii, orase, getPaginiForServiciu, getCategorii } from '../../helpers/data';
import { buildWebPageSchema, buildBreadcrumbSchema } from '../../helpers/structured-data';
import pillarContent from '../../data/pillar-content.json';

export function getStaticPaths() {
  return servicii.map(s => ({ params: { serviciu: s.slug }, props: { serviciu: s } }));
}

const { serviciu } = Astro.props;
const serviciiSimilare = servicii.filter(s => s.categorie === serviciu.categorie && s.slug !== serviciu.slug);
const pillar = pillarContent[serviciu.slug];
---

<Layout>
  <SEOHead
    slot="head"
    title={`Preț ${serviciu.nume} în România - ${serviciu.pretMin}-${serviciu.pretMax} ${serviciu.unitate}`}
    description={`Cât costă ${serviciu.nume.toLowerCase()} în România? Preț orientativ: ${serviciu.pretMin}-${serviciu.pretMax} ${serviciu.unitate}. Prețuri pe ${orase.length} orașe.`}
    canonical={`/${serviciu.slug}/`}
    jsonLd={[
      buildWebPageSchema(`Preț ${serviciu.nume}`, `Cât costă ${serviciu.nume.toLowerCase()} în România`, `/${serviciu.slug}/`),
      buildBreadcrumbSchema([{ label: 'Acasă', href: '/' }, { label: serviciu.nume }]),
    ]}
  />

  <div class="wrap-sm py-8">
    <nav class="text-sm text-neutral-400 mb-6">
      <a href="/" class="hover:text-navy-600 no-underline">Acasă</a> › <span class="text-neutral-600">{serviciu.nume}</span>
    </nav>

    <header class="mb-8">
      <span class="chip chip-navy mb-3">{serviciu.categorie}</span>
      <h1 class="text-2xl sm:text-3xl font-heading font-bold text-neutral-900 mb-3">Cât costă {serviciu.nume.toLowerCase()} în România</h1>
      <p class="text-neutral-500">Preț orientativ național: <strong class="text-navy-700">{serviciu.pretMin}-{serviciu.pretMax} {serviciu.unitate}</strong></p>
    </header>

    <!-- Pillar content -->
    {pillar && (
      <div class="content mb-10">
        <h2>Ce influențează prețul la {serviciu.nume.toLowerCase()}</h2>
        <p>{pillar.ce_influenteaza}</p>

        <h2>Ce include prețul la {serviciu.nume.toLowerCase()}</h2>
        <p>{pillar.ce_include}</p>

        <h2>Sfaturi pentru {serviciu.nume.toLowerCase()}</h2>
        <p>{pillar.sfaturi}</p>
      </div>
    )}

    <!-- Price table per city -->
    <section class="mb-10">
      <h2 class="text-lg font-heading font-bold text-neutral-900 mb-4">Prețuri pe orașe</h2>
      <div class="price-card">
        <div class="price-card-header">
          <div class="flex items-center justify-between">
            <span class="font-bold text-sm">{serviciu.nume}</span>
            <span class="text-navy-300 text-xs">{serviciu.unitate}</span>
          </div>
        </div>
        <div class="price-card-body overflow-x-auto">
          <table class="price-table">
            <thead>
              <tr><th>Oraș</th><th>Minim</th><th>Maxim</th><th>Mediu</th></tr>
            </thead>
            <tbody>
              {orase.map(o => {
                const min = Math.round(serviciu.pretMin * o.coef);
                const max = Math.round(serviciu.pretMax * o.coef);
                const med = Math.round((min + max) / 2);
                return (
                  <tr>
                    <td><a href={`/${serviciu.slug}/${o.slug}/`} class="text-navy-600 hover:text-navy-800 font-medium no-underline">{o.nume}</a></td>
                    <td class="text-neutral-500">{min} lei</td>
                    <td class="text-neutral-500">{max} lei</td>
                    <td class="font-semibold text-neutral-800">{med} lei</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Servicii similare -->
    {serviciiSimilare.length > 0 && (
      <section class="mb-10 pt-8 border-t border-neutral-100">
        <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-4">Prețuri similare</h2>
        <div class="grid sm:grid-cols-2 gap-2">
          {serviciiSimilare.slice(0, 6).map(s => (
            <a href={`/${s.slug}/`} class="group flex items-center justify-between border border-neutral-200 rounded-lg px-4 py-3 no-underline hover:border-navy-300 transition-colors">
              <div>
                <span class="font-medium text-sm text-neutral-800 group-hover:text-navy-700">{s.nume}</span>
                <span class="block text-xs text-neutral-400">{s.pretMin}-{s.pretMax} {s.unitate}</span>
              </div>
              <svg class="w-4 h-4 text-neutral-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="text-xs text-neutral-400">Prețuri orientative, pot varia. Cere ofertă în scris de la profesionist.</p>
  </div>
</Layout>
