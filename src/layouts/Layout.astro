---
import '../styles/global.css';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1e3a5f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin fetchpriority="high" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-navy-900 text-white">
      <div class="wrap flex items-center justify-between h-14">
        <a href="/" class="no-underline shrink-0">
          <img src="/logo.svg" alt="preturiservicii.ro" class="h-10 w-auto invert" width="270" height="50" loading="eager" />
        </a>
        <nav class="hidden sm:flex gap-4 text-sm">
          <a href="/#categorii" class="text-navy-300 hover:text-white no-underline">Categorii</a>
          <a href="/#orase" class="text-navy-300 hover:text-white no-underline">Orașe</a>
        </nav>
      </div>
    </header>
    <main class="flex-1"><slot /></main>
    <footer class="bg-navy-950 text-navy-400 py-8 mt-16">
      <div class="wrap">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm">
          <p>&copy; {year} preturiservicii.ro · Prețuri orientative.</p>
          <nav class="flex gap-4 text-navy-500">
            <a href="/despre/" class="hover:text-navy-300 no-underline">Despre</a>
            <a href="/contact/" class="hover:text-navy-300 no-underline">Contact</a>
            <a href="/confidentialitate/" class="hover:text-navy-300 no-underline">Confidențialitate</a>
            <a href="/termeni/" class="hover:text-navy-300 no-underline">Termeni</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>
